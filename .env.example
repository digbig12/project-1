# ============================================================
# BizAnalytics — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# ─── Database (PostgreSQL) ───────────────────────────────────
# Use a hosted PostgreSQL provider:
#   • Neon:    https://neon.tech (recommended, free tier)
#   • Supabase: https://supabase.com
#   • Vercel Postgres: Available in Vercel dashboard
DATABASE_URL="postgresql://user:password@host:5432/bizanalytics?sslmode=require"

# ─── Authentication ──────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="your-auth-secret-here"

# ─── Google Gemini AI ────────────────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
# Without this, the app uses rule-based fallback responses.
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key-here"
